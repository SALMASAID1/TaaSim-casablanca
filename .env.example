# -------------------------------------------------------------------
# TaaSim Casablanca — Example environment file (template)
# Copy to .env for local use (do not commit .env)
# -------------------------------------------------------------------

# ============================
# Run context (documentation)
# ============================
# host  = you run Python on your machine
# docker = you run Python inside a container on the `taasim` network
TAASIM_RUN_CONTEXT=host

# ============================
# Kafka (GPS Producer)
# ============================
TAASIM_KAFKA_TOPIC=raw.gps

# Host-run (default)
TAASIM_KAFKA_BROKER=localhost:9092

# Docker-run alternative (uncomment if needed)
# TAASIM_KAFKA_BROKER=kafka:29092

# Producer (Trip Requests)
TAASIM_TRIPS_TOPIC=raw.trips
# Max events per simulated second at peak hour (multiplier=1.0)
TAASIM_TRIPS_BASE_RATE_MAX=1.0
# Wall-clock tick size; smaller = smoother rate
TAASIM_TRIPS_TICK_S=0.5
TAASIM_ZONES=16
TAASIM_RIDER_POOL_SIZE=2000
TAASIM_MAX_EVENTS_PER_TICK=500
TAASIM_TIMEZONE=Africa/Casablanca

# ============================
# Input data
# ============================
# Local dataset (fastest start; path is relative to repo root)
TAASIM_DATA_PATH=raw/porto-trips/train.csv

# MinIO / S3A alternative (Python will internally convert s3a:// -> s3://)
# TAASIM_DATA_PATH=s3a://taasim/raw/porto-trips/train.csv
# TAASIM_DATA_PATH=s3a://taasim/curated/casablanca_trips_final/

# ============================
# Simulation knobs (supported)
# ============================
TAASIM_SPEED=10
TAASIM_MAX_TRIPS=200

# Optional knobs (also available via CLI)
# TAASIM_NOISE_SIGMA_DEG=0.0002
# TAASIM_BLACKOUT_PROB=0.05
# TAASIM_BLACKOUT_DELAY_MIN_S=60
# TAASIM_BLACKOUT_DELAY_MAX_S=180

# ============================
# MinIO / S3 credentials (only needed if TAASIM_DATA_PATH starts with s3a:// or s3://)
# ============================
# Host-run MinIO endpoint (used by Python when you run producers on your machine)
AWS_ENDPOINT_URL=http://localhost:9000

# Docker Compose endpoint (used inside containers / docker network)
AWS_ENDPOINT_URL_DOCKER=http://minio:9000

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Helps some AWS clients avoid slow metadata lookups in local dev
AWS_EC2_METADATA_DISABLED=true

# ============================
# Docker Compose service credentials
# ============================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Kafka Connect (S3 sink plugin)
# Used by infra/kafka-connect/connect-entrypoint.sh
CONNECT_S3_VERSION=10.5.0

GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin